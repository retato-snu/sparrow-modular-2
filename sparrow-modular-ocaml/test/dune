   (run bash -c "root=$(cd ../../.. && pwd); ./abstract_speculate_pe_audit.bc --repo-root $root --source-lineage-report abstract_speculate_metaocaml_sparse.source-lineage-check.json --module-boundary-report abstract_speculate_metaocaml_sparse.module-boundary-report.json --fact-provenance-report abstract_speculate_metaocaml_sparse.fact-provenance.json --bta-report abstract_speculate_metaocaml_sparse.bta-report.json --residual-report abstract_speculate_metaocaml_sparse.residual-inspection.json --forbidden-source-report abstract_speculate_metaocaml_sparse.forbidden-source-scan.json --report abstract_speculate_metaocaml_sparse.audit.json"))))

