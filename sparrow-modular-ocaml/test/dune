(rule
 (alias real_sparrow_frontend_global)
 (targets real_sparrow_frontend_global.source-lineage-check.json real_sparrow_frontend_global.audit.json)
 (deps
  real_sparrow_frontend_dump.bc
  real_sparrow_frontend_global_compare.bc
  real_sparrow_acceptance_audit.bc
  fixtures/real_frontend/single_function.c
  fixtures/real_frontend/multi_function.c
  fixtures/real_frontend/globals.c
  fixtures/real_frontend/unreachable_nodes.c
  fixtures/real_frontend/mod_a.c
  fixtures/real_frontend/mod_b.c
  ../doc/real-sparrow-lineage.md
  ../doc/traceability.md
  ../doc/adr/ADR-0001-real-sparrow-frontend-global-fork.md
  ../doc/adr/ADR-0002-real-sparrow-preanalysis-pe.md
  ../doc/experiments/real-sparrow-frontend-global.md
  ../doc/experiments/real-sparrow-preanalysis.md
  ../doc/experiments/real-sparrow-preanalysis-closure.md)
 (action
  (progn
   (run bash -c "root=$(cd ../../.. && pwd); rm -rf $root/../_build/real-sparrow/frontend-global/active $root/../_build/real-sparrow/frontend-global/frozen")
   (run bash -c "root=$(cd ../../.. && pwd); ./real_sparrow_frontend_dump.bc --module fixtures/real_frontend/single_function.c --module fixtures/real_frontend/multi_function.c --module fixtures/real_frontend/globals.c --module fixtures/real_frontend/unreachable_nodes.c --module fixtures/real_frontend/mod_a.c --module fixtures/real_frontend/mod_b.c --out $root/../_build/real-sparrow/frontend-global/active")
   (run bash -c "root=$(cd ../../.. && pwd); mkdir -p $root/_build/real-sparrow; flock $root/_build/real-sparrow/frozen-observer.lock -c \"cd $root/../sparrow && dune exec test/real_frontend_global_observer.exe -- --module $root/test/fixtures/real_frontend/single_function.c --module $root/test/fixtures/real_frontend/multi_function.c --module $root/test/fixtures/real_frontend/globals.c --module $root/test/fixtures/real_frontend/unreachable_nodes.c --module $root/test/fixtures/real_frontend/mod_a.c --module $root/test/fixtures/real_frontend/mod_b.c --out $root/../_build/real-sparrow/frontend-global/frozen\"")
   (run bash -c "root=$(cd ../../.. && pwd); ./real_sparrow_frontend_global_compare.bc --active $root/../_build/real-sparrow/frontend-global/active --reference $root/../_build/real-sparrow/frontend-global/frozen --report real_sparrow_frontend_global.source-lineage-check.json")
   (run bash -c "root=$(cd ../../.. && pwd); ./real_sparrow_acceptance_audit.bc --repo-root $root --report real_sparrow_frontend_global.audit.json"))))

